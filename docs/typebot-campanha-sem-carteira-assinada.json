          "content": {
            "richText": [
              {
                "type": "p",
                "children": [
                  {
                    "text": "Se for um tema fora da campanha, sua mensagem pode seguir para IA ou para atendimento humano."
                  }
                ]
              }
            ]
          },
          "outgoingEdgeId": "edge_router_to_outro_assunto"
        }
      ]
    },
