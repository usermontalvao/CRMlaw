                ]
              }
            },
            {
              "id": "cond_router_humano",
              "outgoingEdgeId": "edge_router_to_humano",
              "content": {
                "logicalOperator": "OR",
                "comparisons": [
                  {
                    "id": "cmp_router_humano",
                    "variableId": "var_entrada_inicial",
                    "comparisonOperator": "Matches regex",
                    "value": "/(humano|atendente|pessoa|advogado|falar com alguem|falar com alguém|atendimento)/i"
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "blk_text_router_fallback",
          "type": "text",
          "content": {
            "richText": [
              {
                "type": "p",
                "children": [
                  {
                    "text": "Entendi. Vou tratar isso como outro assunto."
                  }
                ]
              }
