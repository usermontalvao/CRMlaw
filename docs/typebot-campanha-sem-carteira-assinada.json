            "richText": [
              {
                "type": "p",
                "children": [
                  {
                    "text": "Oi. Eu posso fazer a triagem de caso sobre trabalho sem carteira assinada."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "text": "Se voce quiser outro assunto, eu tambem posso registrar para atendimento inteligente ou humano."
                  }
                ]
              }
            ]
          }
        },
        {
          "id": "blk_router_intro_2",
          "type": "text",
          "content": {
            "richText": [
              {
                "type": "p",
                "children": [
                  {
                    "text": "Escreva em uma frase o que voce precisa."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "text": "Exemplos: trabalhei sem carteira, tenho outra duvida, quero falar com humano."
                  }
                ]
              }
            ]
          }
        },
        {
          "id": "blk_input_entrada_inicial",
          "type": "text input",
          "options": {
            "variableId": "var_entrada_inicial",
            "isLong": true,
            "labels": {
              "placeholder": "Digite sua mensagem",
              "button": "Enviar"
            }
          },
          "outgoingEdgeId": "edge_router_intro_to_router_logic"
        }
      ]
    },
    {
      "id": "grp_router_logic",
      "title": "Decide caminho",
      "graphCoordinates": {
        "x": 660,
        "y": 0
      },
      "blocks": [
        {
          "id": "blk_cond_router",
          "type": "Condition",
          "items": [
            {
              "id": "cond_router_campanha",
              "outgoingEdgeId": "edge_router_to_triagem_intro",
              "content": {
                "logicalOperator": "OR",
                "comparisons": [
                  {
                    "id": "cmp_router_sem_carteira",
                    "variableId": "var_entrada_inicial",
                    "comparisonOperator": "Matches regex",
                    "value": "/(sem carteira|nao assinada|não assinada|nao registr|não registr|registro|trabalhei sem carteira|carteira assinada|vinculo|vínculo|emprego sem registro)/i"
