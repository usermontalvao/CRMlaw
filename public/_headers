# index.html e sw.js NUNCA devem ser cacheados
# Assim, após novo deploy o browser busca o index.html atual com os hashes corretos
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate

# Assets com hash no nome podem ser cacheados para sempre (imutáveis)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
